<UserControl
    x:Class="AirPodsBattery.Controls.BatteryGauge"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Spacing="6" HorizontalAlignment="Center">
        <Grid Width="96" Height="96">
            <ProgressRing
                x:Name="Ring"
                Width="96" Height="96"
                IsIndeterminate="False"
                Minimum="0" Maximum="100"
                Background="#22808080" />
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="0">
                <TextBlock
                    x:Name="PercentText"
                    Text="—"
                    FontSize="22"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Center" />
                <TextBlock
                    x:Name="BoltText"
                    Text="⚡"
                    FontSize="11"
                    HorizontalAlignment="Center"
                    Visibility="Collapsed" />
            </StackPanel>
        </Grid>
        <TextBlock
            x:Name="LabelText"
            FontSize="12"
            Opacity="0.7"
            HorizontalAlignment="Center" />
    </StackPanel>
</UserControl>
